# Copy to /etc/bustimer.env on the Pi and fill in real values.
# This file is safe to commit — no secrets.

# ── Credentials ───────────────────────────────────────────────────────────
TRAFIKLAB_API_KEY=your_key_here

# ── Stop IDs (from transport.integration.sl.se/v1/sites) ─────────────────
BUS_STOP_SITE_ID=5838
TRAIN_STOP_JAKOBSBERG=9702
TRAIN_STOP_BARKARBY=9703

# ── Timing (minutes) ──────────────────────────────────────────────────────
WALK_TO_STOP_MINUTES=5
BUS_TRAVEL_MINUTES=8
TRAIN_BUFFER_MINUTES=2
TRAIN_TRAVEL_JAKOBSBERG=22
TRAIN_TRAVEL_BARKARBY=18
DESTINATION_NAME=Stockholm C

# ── Display environment (Raspberry Pi eglfs) ──────────────────────────────
QT_QPA_PLATFORM=eglfs
QT_QPA_EGLFS_INTEGRATION=eglfs_kms
QT_QPA_EGLFS_KMS_CONFIG=/etc/kiosk-eglfs.json
QT_QPA_EGLFS_WIDTH=800
QT_QPA_EGLFS_HEIGHT=480
QT_QPA_EGLFS_DEPTH=16
QT_QPA_EGLFS_ALWAYS_SET_MODE=1
QT_QPA_EGLFS_HIDECURSOR=1
QT_QPA_EGLFS_DISABLE_INPUT=0
QT_LOGGING_RULES=*.debug=false
